{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "lib": ["ES2022", "WebWorker"],
    "types": ["@cloudflare/workers-types"],
    "allowJs": false,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["alchemy.run.ts", "src/**/*.ts", "tests/**/*.ts"]
}
